# Add this file to auto-check-standard repo as:
#   .github/workflows/notify-site.yml
#
# Required secret in auto-check-standard repo settings:
#   SITE_DISPATCH_TOKEN — a GitHub PAT with repo scope on autochecker-site

name: Notify site on release

on:
  release:
    types: [published]

jobs:
  dispatch:
    runs-on: ubuntu-latest
    steps:
      - name: Send dispatch to autochecker-site
        uses: actions/github-script@v7
        with:
          github-token: ${{ secrets.SITE_DISPATCH_TOKEN }}
          script: |
            const version = context.payload.release.tag_name.replace(/^v/, '');
            await github.rest.repos.createDispatchEvent({
              owner: 'OleksandrShtyka',
              repo:  'autochecker-site',
              event_type: 'extension-release',
              client_payload: { version }
            });
            console.log(`Dispatched version ${version} to autochecker-site`);
